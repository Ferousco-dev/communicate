# Copy this file to `.env` and fill in real values.
# Never commit the real .env — it is in .gitignore.

# Supabase project — Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Deep-link scheme used for the Google OAuth callback.
# Must match the URL scheme registered on iOS (Info.plist) and Android (intent filter).
# Also add this exact URL to Supabase → Authentication → URL configuration → Redirect URLs.
SUPABASE_OAUTH_REDIRECT=io.communicare.app://login-callback/
